generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  phone        String?
  fullName     String
  passwordHash String
  role         String        @default("CLIENT") // CLIENT | ADMIN
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  appointments Appointment[]
  documents    Document[]
}

model Appointment {
  id         Int      @id @default(autoincrement())
  userId     Int?
  guestName  String?
  guestPhone String?
  guestEmail String?
  date       String   // YYYY-MM-DD
  timeSlot   String   // "09:00-10:00"
  service    String
  status     String   @default("PENDING") // PENDING | CONFIRMED | CANCELLED | COMPLETED
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

model Document {
  id          Int      @id @default(autoincrement())
  userId      Int
  filename    String
  storagePath String
  fileSize    Int
  mimeType    String
  description String?
  uploadedBy  String   @default("ADMIN") // ADMIN | CLIENT
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model WorkSchedule {
  id        Int     @id @default(autoincrement())
  dayOfWeek Int // 0=Mon ... 6=Sun
  startTime String // "09:00"
  endTime   String // "18:00"
  slotDuration Int  @default(60) // minutes
  isActive  Boolean @default(true)
}

model BlockedDate {
  id     Int    @id @default(autoincrement())
  date   String // YYYY-MM-DD
  reason String?
}
